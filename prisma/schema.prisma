generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RoleName {
  ADMIN
  MANAGER
  SALES_REP
}

enum ProductType {
  SIMPLE
  VARIANT
  COMPOSITE
}

enum SaleStatus {
  OPEN
  HELD
  COMPLETED
  CANCELLED
  REFUNDED
}

enum InventoryTransactionType {
  OPENING
  SALE
  REFUND
  PURCHASE
  PRODUCTION
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
  STORE_CREDIT
}

enum PaymentDirection {
  SALE
  REFUND
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REVERSED
}

enum DrawerType {
  ONLINE
  OFFLINE
  MIXED
}

enum PurchaseOrderStatus {
  DRAFT
  APPROVED
  RECEIVED
  CANCELLED
}

enum StocktakeStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  APPLIED
  CANCELLED
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DEACTIVATED
  TRIAL
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING_VERIFICATION
}

model Tenant {
  id                    String             @id @default(cuid())
  name                  String
  email                 String?            @unique
  phone                 String?
  website               String?
  logoUrl               String?
  industry              String?
  isEmailVerified       Boolean            @default(false)
  address               String?
  city                  String?
  state                 String?
  zipCode               String?
  country               String?
  status                TenantStatus       @default(ACTIVE)
  subscriptionId        String?            @unique
  settings              Json?              // Tenant-specific settings
  metadata              Json?              // Additional tenant data
  users                 User[]
  categories            Category[]
  products              Product[]
  creditTransactions    CreditTransaction[]
  shifts                Shift[]
  subscription          Subscription?      @relation("TenantSubscription")
  supportTickets        SupportTicket[]
  usageMetrics          UsageMetrics[]
  inventories           Inventory[]
  inventoryTransactions InventoryTransaction[]
  lowStockAlerts        LowStockAlert[]
  stocktakes            Stocktake[]
  sales                 Sale[]
  invoices              Invoice[]
  customers             Customer[]
  suppliers             Supplier[]
  purchaseOrders        PurchaseOrder[]
  productionBatches     ProductionBatch[]
  payments              Payment[]
  auditLogs             AuditLog[]
  verificationTokens    VerificationToken[]
  branches              Branch[]
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt

  @@index([status])
  @@index([subscriptionId])
}

model Branch {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  address     String?
  city        String?
  state       String?
  zipCode     String?
  country     String?
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventories Inventory[]
  inventoryTransactions InventoryTransaction[]
  sales       Sale[]
  shifts      Shift[]
  purchaseOrders PurchaseOrder[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId, name])
  @@index([tenantId, createdAt])
}

model VerificationToken {
  id        String    @id @default(cuid())
  tenantId  String
  email     String
  token     String    @unique
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())
}

model Role {
  id        String    @id @default(cuid())
  name      RoleName  @unique
  users     User[]
  createdAt DateTime  @default(now())
}

model User {
  id                  String              @id @default(cuid())
  tenantId            String
  roleId              String
  name                String
  email               String
  passwordHash        String              @map("password_hash")
  isEmailVerified     Boolean             @default(false)
  status              UserStatus          @default(ACTIVE)
  lastLoginAt         DateTime?
  tenant              Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role                Role                @relation(fields: [roleId], references: [id])
  shifts              Shift[]
  auditLogs           AuditLog[]
  passwordResetTokens PasswordResetToken[]
  supportTickets      SupportTicket[]     @relation("TicketCreator")
  assignedTickets     SupportTicket[]     @relation("TicketAssignee")
  supportMessages     SupportMessage[]
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([email])
}

model Category {
  id          String    @id @default(cuid())
  tenantId    String
  name        String
  description String?
  isActive    Boolean   @default(true)
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products    Product[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId, createdAt])
}

model Product {
  id                String                 @id @default(cuid())
  tenantId          String
  categoryId        String?
  name              String
  sku               String?
  barcode           String?
  imageUrl          String?
  type              ProductType
  price             Decimal                @db.Decimal(14, 2)
  cost              Decimal                @db.Decimal(14, 2)
  taxRate           Decimal                @default(0) @db.Decimal(5, 2)
  tenant            Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category          Category?              @relation(fields: [categoryId], references: [id])
  variants          ProductVariant[]
  inventoryRows     Inventory[]
  saleItems         SaleItem[]
  txnRows           InventoryTransaction[]
  recipeHeads       Recipe[]
  recipeInputs      RecipeItem[]           @relation("RecipeItemRawMaterial")
  purchaseItems     PurchaseItem[]
  productionBatches ProductionBatch[]
  compositeParent   CompositeProductItem[] @relation("CompositeProductParent")
  compositeItems    CompositeProductItem[] @relation("CompositeProductChild")
  lowStockAlerts    LowStockAlert[]
  stocktakeItems    StocktakeLineItem[]    @relation("StocktakeLineItem")
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt

  @@index([tenantId, name])
  @@index([tenantId, createdAt])
  @@unique([tenantId, sku])
  @@unique([tenantId, barcode])
}

model CompositeProductItem {
  id             String   @id @default(cuid())
  parentId       String
  childProductId String
  quantity       Decimal  @db.Decimal(14, 3)
  parent         Product  @relation("CompositeProductParent", fields: [parentId], references: [id], onDelete: Cascade)
  child          Product  @relation("CompositeProductChild", fields: [childProductId], references: [id], onDelete: Restrict)
  createdAt      DateTime @default(now())

  @@unique([parentId, childProductId])
  @@index([parentId])
}

model ProductVariant {
  id            String                 @id @default(cuid())
  productId      String
  name          String
  sku           String
  price         Decimal?               @db.Decimal(14, 2)
  imageUrl      String?
  product       Product                @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryRows Inventory[]
  saleItems     SaleItem[]
  txnRows       InventoryTransaction[]
  lowStockAlerts LowStockAlert[]
  stocktakeItems StocktakeLineItem[]    @relation("StocktakeLineItem")
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  @@unique([productId, sku])
}

model Inventory {
  id               String      @id @default(cuid())
  tenantId         String
  branchId         String?
  productId        String
  productVariantId String?
  quantity         Decimal     @default(0) @db.Decimal(14, 3)
  tenant           Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product          Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  @@unique([tenantId, branchId, productId, productVariantId])
  @@index([tenantId, branchId, productId])
  @@index([tenantId, quantity])
  @@index([branchId, quantity])
  @@index([productId, quantity])
  @@index([tenantId, updatedAt])
  @@index([branchId, updatedAt])
}

model InventoryTransaction {
  id               String                   @id @default(cuid())
  tenantId         String
  branchId         String?
  productId        String
  productVariantId String?
  type             InventoryTransactionType
  quantity         Decimal                  @db.Decimal(14, 3)
  balanceAfter     Decimal                  @db.Decimal(14, 3)
  referenceType    String
  referenceId      String
  note             String?
  tenant           Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch           Branch?                  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  product          Product                  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant?          @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  createdAt        DateTime                 @default(now())

  @@index([tenantId, productId, createdAt])
  @@index([branchId])
  @@index([referenceType, referenceId])
}

model LowStockAlert {
  id               String    @id @default(cuid())
  tenantId         String
  productId        String
  productVariantId String?
  quantity         Decimal   @db.Decimal(14, 3)
  isResolved       Boolean   @default(false)
  resolvedAt       DateTime?
  tenant           Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product          Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([tenantId, productId, productVariantId], name: "unique_low_stock_alert")
  @@index([tenantId, isResolved])
}

model Stocktake {
  id         String          @id @default(cuid())
  tenantId   String
  name       String
  status     StocktakeStatus @default(PLANNED)
  notes      String?
  tenant     Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lineItems  StocktakeLineItem[]
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  startedAt  DateTime?
  completedAt DateTime?

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model StocktakeLineItem {
  id               String    @id @default(cuid())
  stocktakeId      String
  productId        String
  productVariantId String?
  systemCount      Decimal   @db.Decimal(14, 3)
  physicalCount    Decimal   @db.Decimal(14, 3)
  variance         Decimal   @db.Decimal(14, 3)
  notes            String?
  stocktake        Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  product          Product   @relation("StocktakeLineItem", fields: [productId], references: [id], onDelete: Cascade)
  productVariant   ProductVariant? @relation("StocktakeLineItem", fields: [productVariantId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@unique([stocktakeId, productId, productVariantId])
  @@index([stocktakeId, productId])
}

model Customer {
  id            String    @id @default(cuid())
  tenantId      String
  name          String
  phone         String?
  email         String?
  creditBalance Decimal   @default(0) @map("credit_balance") @db.Decimal(14, 2)
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales         Sale[]
  creditTransactions CreditTransaction[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId, name])
  @@index([tenantId, createdAt])
}

model CreditTransaction {
  id          String   @id @default(cuid())
  tenantId    String
  customerId  String
  amount      Decimal  @db.Decimal(14, 2)
  balanceAfter Decimal @map("balance_after") @db.Decimal(14, 2)
  type        CreditTransactionType
  referenceType String? @map("reference_type")
  referenceId   String? @map("reference_id")
  note        String?
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@index([tenantId, customerId, createdAt])
}

enum CreditTransactionType {
  CREDIT
  DEBIT
  REFUND
  ADJUSTMENT
}

model Sale {
  id              String      @id @default(cuid())
  tenantId        String
  branchId        String?
  customerId      String?
  shiftId         String?
  saleNumber      String      @map("sale_number")
  status          SaleStatus
  taxRateOverride Decimal?    @map("tax_rate_override") @db.Decimal(5, 2)
  subtotalAmount  Decimal     @default(0) @map("subtotal_amount") @db.Decimal(14, 2)
  discountAmount  Decimal     @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxAmount       Decimal     @default(0) @map("tax_amount") @db.Decimal(14, 2)
  totalAmount     Decimal     @default(0) @map("total_amount") @db.Decimal(14, 2)
  paidAmount      Decimal     @default(0) @map("paid_amount") @db.Decimal(14, 2)
  note            String?
  tenant          Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch          Branch?     @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer        Customer?   @relation(fields: [customerId], references: [id], onDelete: SetNull)
  shift           Shift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items           SaleItem[]
  payments        Payment[]
  invoice         Invoice?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  heldAt          DateTime?
  completedAt     DateTime?
  cancelledAt     DateTime?
  refundedAt      DateTime?

  @@unique([tenantId, saleNumber])
  @@index([tenantId, branchId, status, createdAt])
  @@index([tenantId, shiftId])
  @@index([tenantId, status, completedAt])
}

model Invoice {
  id             String    @id @default(cuid())
  tenantId       String
  saleId         String    @unique
  invoiceNumber  String    @map("invoice_number")
  subtotalAmount Decimal   @map("subtotal_amount") @db.Decimal(14, 2)
  discountAmount Decimal   @map("discount_amount") @db.Decimal(14, 2)
  taxAmount      Decimal   @map("tax_amount") @db.Decimal(14, 2)
  totalAmount    Decimal   @map("total_amount") @db.Decimal(14, 2)
  issuedAt       DateTime  @map("issued_at") @default(now())
  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sale           Sale      @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, invoiceNumber])
  @@index([tenantId, issuedAt])
}

model SaleItem {
  id               String          @id @default(cuid())
  saleId           String
  productId        String
  productVariantId String?
  quantity         Decimal         @db.Decimal(14, 3)
  price            Decimal         @db.Decimal(14, 2)
  taxRate          Decimal         @default(0) @map("tax_rate") @db.Decimal(5, 2)
  discountAmount   Decimal         @default(0) @map("discount_amount") @db.Decimal(14, 2)
  taxAmount        Decimal         @default(0) @map("tax_amount") @db.Decimal(14, 2)
  lineTotal        Decimal         @map("line_total") @db.Decimal(14, 2)
  sale             Sale            @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product          Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id], onDelete: Restrict)
  createdAt        DateTime        @default(now())

  @@index([saleId])
}

model Payment {
  id          String           @id @default(cuid())
  tenantId    String
  saleId      String
  method      PaymentMethod
  direction   PaymentDirection @default(SALE)
  status      PaymentStatus    @default(COMPLETED)
  amount      Decimal          @db.Decimal(14, 2)
  reference   String?
  externalRef String?          // External payment reference (e.g., payment gateway ID, terminal ID)
  sale        Sale             @relation(fields: [saleId], references: [id], onDelete: Cascade)
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId, saleId, createdAt])
  @@index([tenantId, status, createdAt])
  @@unique([tenantId, externalRef])
}

model Supplier {
  id             String          @id @default(cuid())
  tenantId       String
  name           String
  email          String?
  phone          String?
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  branchId     String?
  supplierId   String
  status       PurchaseOrderStatus
  tenant       Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?             @relation(fields: [branchId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  items        PurchaseItem[]
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  @@index([tenantId, branchId, status, createdAt])
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  productId       String
  quantity        Decimal       @db.Decimal(14, 3)
  cost            Decimal       @db.Decimal(14, 2)
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product         Product       @relation(fields: [productId], references: [id], onDelete: Restrict)
}

model Recipe {
  id          String       @id @default(cuid())
  productId   String       @unique
  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  items       RecipeItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model RecipeItem {
  id             String    @id @default(cuid())
  recipeId       String
  rawMaterialId  String
  quantity       Decimal   @db.Decimal(14, 3)
  recipe         Recipe    @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  rawMaterial    Product   @relation("RecipeItemRawMaterial", fields: [rawMaterialId], references: [id], onDelete: Restrict)
}

model ProductionBatch {
  id                String    @id @default(cuid())
  tenantId          String
  productId         String
  quantityProduced  Decimal   @map("quantity_produced") @db.Decimal(14, 3)
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product           Product   @relation(fields: [productId], references: [id], onDelete: Restrict)
  createdAt         DateTime  @default(now())
}

model AuditLog {
  id         String    @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entity     String
  entityId   String
  metadata   Json?
  timestamp  DateTime  @default(now())
  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, entity, entityId, timestamp])
}

model Shift {
  id                String         @id @default(cuid())
  tenantId          String
  branchId          String?
  userId            String
  openedAt          DateTime       @default(now())
  closedAt          DateTime?
  openingBalance    Decimal        @map("opening_balance") @db.Decimal(14, 2)
  closingBalance    Decimal?       @map("closing_balance") @db.Decimal(14, 2)
  cashSales         Decimal        @default(0) @map("cash_sales") @db.Decimal(14, 2)
  cardSales         Decimal        @default(0) @map("card_sales") @db.Decimal(14, 2)
  otherSales        Decimal        @default(0) @map("other_sales") @db.Decimal(14, 2)
  status            ShiftStatus    @default(OPEN)
  drawerType        DrawerType     @default(OFFLINE)
  onlineDrawerBalance Decimal?      @map("online_drawer_balance") @db.Decimal(14, 2)
  offlineDrawerBalance Decimal?     @map("offline_drawer_balance") @db.Decimal(14, 2)
  actualCashCount    Decimal?       @map("actual_cash_count") @db.Decimal(14, 2)
  discrepancy       Decimal?       @db.Decimal(14, 2)
  notes             String?
  tenant            Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sales             Sale[]
  reconciliations   ShiftReconciliation[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([tenantId, userId, status])
  @@index([tenantId, branchId, status])
}

enum ShiftStatus {
  OPEN
  CLOSED
}

model ShiftReconciliation {
  id          String   @id @default(cuid())
  tenantId    String
  shiftId     String
  shift       Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  // Expected amounts
  expectedCash      Decimal  @map("expected_cash") @db.Decimal(14, 2)
  expectedCard      Decimal  @map("expected_card") @db.Decimal(14, 2)
  expectedTransfer  Decimal  @map("expected_transfer") @db.Decimal(14, 2)
  expectedMobile    Decimal  @map("expected_mobile") @db.Decimal(14, 2)
  expectedTotal     Decimal  @map("expected_total") @db.Decimal(14, 2)

  // Actual amounts counted
  actualCash       Decimal  @map("actual_cash") @db.Decimal(14, 2)
  actualCard       Decimal  @map("actual_card") @db.Decimal(14, 2)
  actualTransfer   Decimal  @map("actual_transfer") @db.Decimal(14, 2)
  actualMobile     Decimal  @map("actual_mobile") @db.Decimal(14, 2)
  actualTotal      Decimal  @map("actual_total") @db.Decimal(14, 2)

  // Discrepancies
  cashDiscrepancy    Decimal  @map("cash_discrepancy") @db.Decimal(14, 2)
  cardDiscrepancy    Decimal  @map("card_discrepancy") @db.Decimal(14, 2)
  transferDiscrepancy Decimal  @map("transfer_discrepancy") @db.Decimal(14, 2)
  mobileDiscrepancy  Decimal  @map("mobile_discrepancy") @db.Decimal(14, 2)
  totalDiscrepancy   Decimal  @map("total_discrepancy") @db.Decimal(14, 2)

  notes       String?
  reconciledBy String  @map("reconciled_by")  // User who reconciled
  reconciledAt DateTime @map("reconciled_at")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId, shiftId])
  @@index([tenantId, reconciledAt])
}

// Subscription Management
model SubscriptionPlan {
  id          String        @id @default(cuid())
  name        String
  description String?
  price       Decimal       @db.Decimal(10, 2)
  billingCycle BillingCycle
  isActive    Boolean       @default(true)
  limits      Json          // { users: 10, branches: 5, products: 1000, ... }
  features    Json          // ["inventory", "reports", "api_access", ... }
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  subscriptions Subscription[]
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

model Subscription {
  id          String            @id @default(cuid())
  tenantId    String            @unique
  planId      String
  status      SubscriptionStatus
  startDate   DateTime
  endDate     DateTime?
  cancelledAt DateTime?
  usage       Json              // Current usage metrics
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  
  tenant      Tenant            @relation("TenantSubscription", fields: [tenantId], references: [id], onDelete: Cascade)
  plan        SubscriptionPlan  @relation(fields: [planId], references: [id])
  
  @@index([tenantId, status])
}

enum SubscriptionStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  EXPIRED
}

// Support System
model SupportTicket {
  id          String         @id @default(cuid())
  tenantId    String
  userId      String
  subject     String
  description String
  status      TicketStatus   @default(OPEN)
  priority    TicketPriority @default(MEDIUM)
  category    TicketCategory
  assignedTo  String?        // Admin user ID
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  resolvedAt  DateTime?
  
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User           @relation("TicketCreator", fields: [userId], references: [id], onDelete: Cascade)
  assignee    User?          @relation("TicketAssignee", fields: [assignedTo], references: [id])
  messages    SupportMessage[]
  
  @@index([tenantId, status])
  @@index([assignedTo, status])
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  BILLING
  TECHNICAL
  FEATURE_REQUEST
  BUG_REPORT
  ACCOUNT_ISSUE
  OTHER
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  senderId  String   // Can be tenant user or admin
  content   String
  isFromAdmin Boolean @default(false)
  createdAt DateTime @default(now())
  
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  sender    User          @relation(fields: [senderId], references: [id])
  
  @@index([ticketId, createdAt])
}

// Usage Tracking
model UsageMetrics {
  id          String   @id @default(cuid())
  tenantId    String
  metric      String   // "users", "branches", "products", "api_calls"
  value       Int
  recordedAt  DateTime @default(now())
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  @@unique([tenantId, metric, recordedAt])
  @@index([tenantId, metric])
}

// Super Admin Users (separate from tenant users)
model AdminUser {
  id          String   @id @default(cuid())
  email       String   @unique
  password    String
  firstName   String
  lastName    String
  role        AdminRole @default(SUPER_ADMIN)
  isActive    Boolean  @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  auditLogs   AdminAuditLog[]
  
  @@index([email])
}

enum AdminRole {
  SUPER_ADMIN
  SUPPORT_ADMIN
  BILLING_ADMIN
}

// Admin Actions Audit
model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String
  action      String   // "suspend_tenant", "change_plan", "resolve_ticket"
  targetId    String?  // Target entity ID
  targetType  String?  // "tenant", "user", "subscription"
  details     Json?    // Action details
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  admin       AdminUser @relation(fields: [adminId], references: [id])
  
  @@index([adminId, action])
  @@index([targetType, targetId])
}

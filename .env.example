DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ptlpos?schema=public"
REDIS_URL="redis://localhost:6379"
PORT=3000
NODE_ENV="development"
APP_NAME="PTLPOS"
JWT_SECRET="your-secret-key-change-in-production"
JWT_EXPIRATION="24h"

# Mailgun Email Configuration
# Get these from your Mailgun account at https://app.mailgun.com
MAILGUN_DOMAIN="sandbox.xxxxx.mailgun.org"
MAILGUN_API_KEY="key-xxxxxxxxxxxxxxxxxxxx"
MAILGUN_FROM_EMAIL="noreply@yourapp.com"
SUPABASE_BUCKET=ptlpos
SUPABASE_KEY=ANON_PUBLIC_API_KEY
SUPABASE_URL=https://projecturl.supabase.co

# CORS Configuration
# Comma-separated list of allowed origins for frontend URLs
# Examples:
# Development: "http://localhost:3000,http://127.0.0.1:3000"
# Production: "https://your-frontend-domain.com,https://www.your-frontend-domain.com"
# Allow all (not recommended for production): "*"
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"

